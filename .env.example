# App URL used in verification links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email verification token secret (generate with: openssl rand -base64 48)
EMAIL_VERIFICATION_SECRET=replace-with-a-long-random-secret-value

# Gmail SMTP settings for NextTalent
# Use a Google App Password, not your regular Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-google-app-password
MAIL_FROM=NextStep Talent <your-gmail-address@gmail.com>
